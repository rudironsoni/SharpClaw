+    private static async Task ForwardRunEventsAsync(GatewayDispatcher dispatcher, RunCoordinator runCoordinator, string runId)
+    {
+        try
+        {
+            await foreach (var runEvent in runCoordinator.ReadEventsAsync(runId).ConfigureAwait(false))
+            {
+                var eventFrame = new EventFrame($"runs.{runId}", runEvent.Event, runEvent.Data);
+                await dispatcher.PublishEventAsync($"runs.{runId}", eventFrame).ConfigureAwait(false);
+            }
+        }
+        catch
+        {
+            // Background forwarding stopped
+        }
+    }
